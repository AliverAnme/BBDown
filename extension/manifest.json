{
  "manifest_version": 3,
  "name": "BBDown DRM Key Extractor",
  "version": "1.0",
  "description": "一键提取B站课程/番劇 DRM 解密密钥，配合 BBDown 使用",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.bilibili.com/*",
    "https://bvc-drm.bilivideo.com/*"
  ],
  "content_scripts": [{
    "matches": ["https://www.bilibili.com/cheese/*", "https://www.bilibili.com/bangumi/*"],
    "js": ["content.js"],
    "run_at": "document_start",
    "world": "MAIN"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BBDown DRM Keys"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
